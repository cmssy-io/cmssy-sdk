{
  "name": "@cmssy/core",
  "version": "9.0.0",
  "description": "Framework-agnostic cmssy client: content, commerce, config, editor protocol. No React, no Next.",
  "keywords": [
    "cmssy",
    "cms",
    "headless",
    "graphql",
    "client"
  ],
  "homepage": "https://cmssy.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmssy-io/cmssy-sdk.git",
    "directory": "packages/core"
  },
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./preflight": {
      "types": "./dist/preflight.d.ts",
      "import": "./dist/preflight.js",
      "require": "./dist/preflight.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "graphql": "^16.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@cmssy/types": "0.28.0",
    "jose": "^6.2.3"
  }
}
