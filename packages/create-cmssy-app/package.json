{
  "name": "create-cmssy-app",
  "version": "8.0.0",
  "description": "Start a cmssy-powered app (Next.js or Astro) that works, is editable, and proves it stays that way.",
  "type": "module",
  "bin": {
    "create-cmssy-app": "./dist/index.js"
  },
