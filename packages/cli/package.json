{
  "name": "@cmssy/cli",
  "version": "9.4.0",
  "description": "The cmssy CLI: `cmssy init` wires cmssy into an existing Next.js, Astro or React Router app; `cmssy link` connects it to a workspace and verifies the editor wiring.",
  "keywords": [
    "cmssy",
    "cli",
    "init",
    "link"
  ],
  "homepage": "https://cmssy.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmssy-io/cmssy-sdk.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "cmssy": "./dist/index.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cmssy/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
