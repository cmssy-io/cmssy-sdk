{
  "name": "@cmssy/next",
  "version": "0.7.4",
  "description": "Next.js App Router bindings for cmssy headless sites (createCmssyPage + draft preview)",
  "keywords": [
    "cmssy",
    "cms",
    "headless",
    "nextjs",
    "next",
    "app-router"
  ],
  "homepage": "https://cmssy.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmssy-io/cmssy-sdk.git",
    "directory": "packages/next"
  },
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@cmssy/react": "^0.7.4",
    "next": ">=15",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@cmssy/react": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "jose": "^6.2.3"
  }
}
